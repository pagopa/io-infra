<fragment>
	<!-- 1. Extract and validate Authorization header -->
	<set-variable name="authHeader" value="@(context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, &quot;&quot;))" />
	<choose>
		<when condition="@(!context.Variables.GetValueOrDefault&lt;string&gt;(&quot;authHeader&quot;).StartsWith(&quot;Bearer &quot;))">
			<return-response>
				<set-status code="401" reason="Unauthorized" />
				<set-header name="Content-Type" exists-action="override">
					<value>application/json</value>
				</set-header>
				<set-body>{"title": "Unauthorized", "status": 401, "detail": "Missing or invalid Authorization header"}</set-body>
			</return-response>
		</when>
	</choose>

	<!-- 2. Extract the Bearer token to use as cache key -->
	<set-variable name="bearerToken" value="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;authHeader&quot;).Substring(&quot;Bearer &quot;.Length).Trim())" />

	<!-- 2b. Validate that the Bearer token is non-empty -->
	<choose>
		<when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;bearerToken&quot;).Length &lt; 64)">
			<return-response>
				<set-status code="401" reason="Unauthorized" />
				<set-header name="Content-Type" exists-action="override">
					<value>application/json</value>
				</set-header>
				<set-body>{"title": "Unauthorized", "status": 401, "detail": "Missing or invalid Bearer token"}</set-body>
			</return-response>
		</when>
	</choose>

	<!-- 3. Lookup user data in APIM internal cache -->
	<cache-lookup-value
		key="@(&quot;{{session-token-cache-prefix}}&quot; + context.Variables.GetValueOrDefault&lt;string&gt;(&quot;bearerToken&quot;))"
		variable-name="cachedUserData"
		caching-type="internal" />

	<!-- 4. If cache HIT, use cached value; otherwise call introspection -->
	<choose>
		<when condition="@(context.Variables.ContainsKey(&quot;cachedUserData&quot;))">
			<!-- Cache HIT: use the cached base64-encoded user data -->
			<set-header name="Authorization" exists-action="delete" />
			<set-header name="x-user" exists-action="override">
				<value>@((string)context.Variables["cachedUserData"])</value>
			</set-header>
		</when>

		<otherwise>
			<!-- Cache MISS: call introspection endpoint -->
			<send-request mode="new" response-variable-name="introspectionResponse" timeout="10" ignore-error="false">
				<set-url>https://127.0.0.1{{session-manager-introspection-url}}</set-url>
				<set-method>GET</set-method>

				<set-header name="Content-Type" exists-action="override">
					<value>application/json</value>
				</set-header>

				<set-header name="Authorization" exists-action="override">
					<value>@(context.Variables.GetValueOrDefault&lt;string&gt;("authHeader"))</value>
				</set-header>

				<set-header name="Host">
					<value>{{platform-api-gateway-hostname-internal}}</value>
				</set-header>
			</send-request>

			<choose>
				<when condition="@(((IResponse)context.Variables[&quot;introspectionResponse&quot;]).StatusCode == 200)">

					<!-- Parse the introspection response and extract TTL -->
					<set-variable
						name="introspectionBody"
						value="@(((IResponse)context.Variables[&quot;introspectionResponse&quot;]).Body.As&lt;JObject&gt;())" />

					<set-variable
						name="tokenTtl"
						value="@(Math.Min(((JObject)context.Variables[&quot;introspectionBody&quot;]).Value&lt;int&gt;(&quot;token_remaining_ttl&quot;), 300))" />

					<set-variable
						name="userData"
						value="@(Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(((JObject)context.Variables[&quot;introspectionBody&quot;]).ToString())))" />

					<!-- Store the base64-encoded user data in cache -->
					<choose>
						<when condition="@((int)context.Variables[&quot;tokenTtl&quot;] &gt; 0)">
							<cache-store-value
								key="@(&quot;{{session-token-cache-prefix}}&quot; + context.Variables.GetValueOrDefault&lt;string&gt;(&quot;bearerToken&quot;))"
								value="@((string)context.Variables[&quot;userData&quot;])"
								duration="@((int)context.Variables[&quot;tokenTtl&quot;])"
								caching-type="internal" />
						</when>
					</choose>

					<!-- Remove the Authorization header -->
					<set-header name="Authorization" exists-action="delete" />

					<!-- Set the x-user header -->
					<set-header name="x-user" exists-action="override">
						<value>@((string)context.Variables["userData"])</value>
					</set-header>
				</when>

				<when condition="@(((IResponse)context.Variables[&quot;introspectionResponse&quot;]).StatusCode == 401)">
					<return-response>
						<set-status code="401" reason="Unauthorized" />
					</return-response>
				</when>

				<otherwise>
					<return-response>
						<set-status code="500" reason="Internal Server Error" />
						<set-header name="Content-Type" exists-action="override">
							<value>application/json</value>
						</set-header>
						<set-body>{"title": "Proxy Error", "status": 500, "detail": "The token introspection-endpoint returns an error"}</set-body>
					</return-response>
				</otherwise>
			</choose>
		</otherwise>
	</choose>
</fragment>